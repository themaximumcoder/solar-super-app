datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Report {
  id           String   @id @default(cuid())
  mhsNumber    String
  customerName String
  address      String
  systemSize   String
  picOnsite    String
  documentUrl  String
  createdAt    DateTime @default(now())
}
